# Copy to .env and fill in. NEVER commit .env - it is in .gitignore.

# ---- Required ----
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# ---- Optional ----
# OPENAI_MODEL=gpt-4o-mini

# MCP endpoints. Defaults are correct for local dev and for deployment,
# where all four processes run in one instance.
# HOTEL_MCP_URL=http://localhost:8001/mcp
# FLIGHT_MCP_URL=http://localhost:8002/mcp
# ACTIVITY_MCP_URL=http://localhost:8003/mcp

# Ports the MCP servers bind to.
# HOTEL_MCP_PORT=8001
# FLIGHT_MCP_PORT=8002
# ACTIVITY_MCP_PORT=8003

# FastAPI port. Most hosts inject this.
# PORT=8000
